local function getEntityPrimaryPart(entity)
    if entity.PrimaryPart then return entity.PrimaryPart end
    return entity:FindFirstChild("HumanoidRootPart") or entity:FindFirstChild("Torso") or entity:FindFirstChild("UpperTorso")
end

local function isEntityAlive(entity)
    local humanoid = entity:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function isBlacklisted(entity)
    return blacklist[entity] or blacklist[entity.Name] or false
end

local function findNextEntity()
    for _, entity in ipairs(ENTITY_FOLDER:GetChildren()) do
        if isEntityAlive(entity) and not isBlacklisted(entity) then
            return entity
        end
    end
    return nil
end

local function switchToEntity(newEntity)
    if not newEntity then
        currentEntity = nil
        return
    end
    if diedConnection then
        diedConnection:Disconnect()
        diedConnection = nil
    end
    currentEntity = newEntity
    local humanoid = currentEntity:FindFirstChildOfClass("Humanoid")
    if humanoid then
        diedConnection = humanoid.Died:Connect(function()
            local nextEntity = findNextEntity()
            if nextEntity then switchToEntity(nextEntity) else currentEntity = nil end
        end)
    end
end

local function updatePosition()
    if not enabled or not currentEntity then return end
    local primaryPart = getEntityPrimaryPart(currentEntity)
    if not primaryPart then return end
    local targetPos = primaryPart.Position + Vector3.new(0, -beneathDistance, 0)
    humanoidRootPart.CFrame = CFrame.new(targetPos) * (humanoidRootPart.CFrame - humanoidRootPart.Position)
end

-- GUI update functions
local function updateCurrentEntityLabel()
    if entityLabel then
        entityLabel.Text = "Current: " .. (currentEntity and currentEntity.Name or "none")
