-- Global function
_G.addEntityException = function(thing)
    if typeof(thing) == "Instance" then
        blacklist[thing] = true
    elseif type(thing) == "string" then
        blacklist[thing] = true
    else
        warn("addEntityException: expected string or Instance")
    end
    rebuildBlacklistDisplay()
end

