UserInputService.InputChanged:Connect(function(input)
    if dragActive and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mousePos = UserInputService:GetMouseLocation()
        local delta = mousePos - dragStart
        dragDistance = dragDistance + delta.Magnitude
        if dragDistance > dragThreshold then
            smallIcon.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and dragActive then
        if dragDistance <= dragThreshold then
            onSmallIconClick()
        end
        dragActive = false
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if awaitingKey then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local key = input.KeyCode
            if key ~= Enum.KeyCode.Unknown then
                if awaitingFor == "toggle" then
                    toggleKey = key
                    toggleKeyBtn.Text = "Toggle Key: " .. key.Name
                elseif awaitingFor == "hide" then
                    hideKey = key
                    hideKeyBtn.Text = "Hide Key: " .. key.Name
                    hideHint.Text = key.Name:sub(1,1)
                end
                awaitingKey = false
                awaitingFor = nil
            end
        end
        return
    end

    if input.KeyCode == toggleKey then
        toggle()
    elseif input.KeyCode == hideKey then
        setMainVisible(not mainFrame.Visible)
    end
end)

