local function updateToggleButton()
    if toggleBtn then
        toggleBtn.Text = enabled and "Disable" or "Enable"
        toggleBtn.BackgroundColor3 = enabled and Color3.new(1, 0.3, 0.3) or Color3.new(0.3, 1, 0.3)
    end
end

local function rebuildBlacklistDisplay()
    if not blacklistContainer then return end
    for _, child in pairs(blacklistContainer:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local sorted = {}
    for name, _ in pairs(blacklist) do
        if type(name) == "string" then table.insert(sorted, name) end
    end
    table.sort(sorted)
    for _, name in ipairs(sorted) do
        local itemFrame = Instance.new("Frame")
        itemFrame.Size = UDim2.new(1, 0, 0, 24)
        itemFrame.BackgroundTransparency = 1
        itemFrame.Parent = blacklistContainer

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(0.8, 0, 1, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = name
        nameLabel.TextColor3 = Color3.new(1, 1, 1)
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Font = Enum.Font.Gotham
        nameLabel.TextSize = 14
        nameLabel.Parent = itemFrame

        local removeBtn = Instance.new("TextButton")
        removeBtn.Size = UDim2.new(0.2, 0, 1, 0)
        removeBtn.Position = UDim2.new(0.8, 0, 0, 0)
        removeBtn.Text = "X"
        removeBtn.TextColor3 = Color3.new(1, 1, 1)
        removeBtn.BackgroundColor3 = Color3.new(0.8, 0.2, 0.2)
        removeBtn.Font = Enum.Font.GothamBold
        removeBtn.TextSize = 14
        removeBtn.Parent = itemFrame

        removeBtn.MouseButton1Click:Connect(function()
            blacklist[name] = nil
            rebuildBlacklistDisplay()
        end)
    end
end

-- Toggle function
local function toggle()
    enabled = not enabled
    updateToggleButton()
    if enabled then
        local firstEntity = findNextEntity()
        if firstEntity then switchToEntity(firstEntity) else currentEntity = nil end
    else
        if diedConnection then
            diedConnection:Disconnect()
            diedConnection = nil
        end
        currentEntity = nil
    end
    updateCurrentEntityLabel()
end

local function setMainVisible(visible)
